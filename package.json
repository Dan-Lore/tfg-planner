{
  "name": "tfg-planner",
  "version": "0.1.0",
  "description": "Production flowchart planner for TerraFirmaGreg-Modern modpack",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -b && vite build --mode pages",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "build-pack": "tsx tools/parser/src/cli.ts build-pack",
    "parser:validate": "tsx tools/parser/src/cli.ts validate"
  },
  "dependencies": {
    "@babel/parser": "^8.0.0",
    "@babel/traverse": "^8.0.0",
    "@babel/types": "^8.0.0",
    "@xyflow/react": "^12.6.0",
    "adm-zip": "^0.5.17",
    "i18next": "^25.2.1",
    "js-yaml": "^4.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^15.5.2",
    "react-router-dom": "^7.6.2",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "tsx": "^4.19.4",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  }
}
