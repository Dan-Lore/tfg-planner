{
  "name": "tfg-planner",
  "version": "0.2.0",
  "description": "Production flowchart planner for TerraFirmaGreg-Modern modpack",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b && tsc -p tsconfig.parser.json",
    "build": "npm run typecheck && vite build",
    "build:pages": "npm run typecheck && vite build --mode pages",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "build-pack": "tsx tools/parser/src/cli.ts build-pack",
    "bootstrap-snapshot": "node tools/parser/scripts/bootstrap-snapshot-from-pack.mjs",
    "generate-flow-index": "vitest run src/lib/generate-flow-index.test.ts",
    "recanonicalize-pack": "vitest run tools/parser/tests/recanonicalize-pack.test.ts -- --rewrite",
    "resume-tfg-server-export": "node tools/parser/scripts/run-tfg-server-export.mjs",
    "parser:validate": "tsx tools/parser/src/cli.ts validate",
    "check-scheme": "vite-node --config vitest.config.ts tools/check-scheme.ts",
    "lint:arch": "depcruise src tools/parser/src --config .dependency-cruiser.cjs",
    "lint:knip": "knip --include files,dependencies,duplicates,exports",
    "lint:semgrep": "semgrep --config .semgrep.yml --error --quiet src tools/parser/src",
    "lint:agent": "npm run lint:arch && npm run lint:knip && npm run lint:semgrep"
  },
  "dependencies": {
    "@xyflow/react": "^12.6.0",
    "adm-zip": "^0.5.17",
    "i18next": "^25.2.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^15.5.2",
    "react-router-dom": "^7.6.2",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@babel/parser": "^8.0.0",
    "@babel/traverse": "^8.0.0",
    "@babel/types": "^8.0.0",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "dependency-cruiser": "^18.0.0",
    "knip": "^6.23.0",
    "tsx": "^4.19.4",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  }
}
