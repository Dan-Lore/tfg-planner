{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "tools/debug-scheme-flow.ts",
    "tools/shard-monolith-pack.mjs",
    "tools/check-scheme.ts",
    "tools/parser/scripts/*.{mjs,js}"
  ],
  "project": ["src/**/*.{ts,tsx}", "tools/**/*.{ts,mjs}"],
  "ignore": ["src/test/**", "src/test-fixtures/**"],
  "ignoreFiles": [
    ".cache/**",
    "dist/**",
    "public/data/**",
    "coverage/**",
    "tools/parser/snapshots/**",
    "tools/parser/substrate-dumps/**",
    "tools/parser/scripts/analyze-lang-coverage.ts",
    "src/calculator/flow-result-fixtures.ts"
  ],
  "ignoreIssues": {
    "tools/parser/src/pipeline/recipe-id-aliases.ts": ["duplicates"],
    "tools/parser/src/snapshot/manifest.ts": ["duplicates"],
    "src/calculator/**": ["exports"],
    "src/lib/**": ["exports"],
    "src/canvas/**": ["exports"],
    "src/data/**": ["exports"],
    "src/schema/**": ["exports"],
    "src/stores/**": ["exports"],
    "src/i18n/**": ["exports"],
    "src/scheme-check/**": ["exports"],
    "src/theme/**": ["exports"],
    "tools/parser/src/**": ["exports"]
  },
  "vite": {
    "config": ["vite.config.ts"]
  },
  "vitest": {
    "config": ["vitest.config.ts"],
    "entry": ["src/**/*.test.ts", "tools/parser/tests/**/*.test.ts"]
  }
}
